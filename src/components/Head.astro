---
import favicon from "@assets/images/favicon.ico";
const { title, description } = Astro.props;
---

<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter+Tight:ital,wght@0,100..900;1,100..900&family=Inter:ital,opsz,wght@0,14..32,100..900;1,14..32,100..900&display=swap"
  rel="stylesheet"
/>
<link rel="icon" type="image/svg+xml" href={favicon} />
<meta name="generator" content={Astro.generator} />
<link rel="sitemap" href="/sitemap-index.xml" />
<title>{`${title} - ${description}`}</title>
<meta name="description" content={description} />

<script
  data-goatcounter="https://my-account.goatcounter.com/count"
  async
  src="//gc.zgo.at/count.js"></script>
<meta property="og:title" content={title} />
<meta property="og:type" content="website" />
<meta property="og:url" content="http://www.biginner.es/" />
<meta property="og:description" content={description} />
<meta property="og:image" content={favicon} />
<meta property="og:image:alt" content="" />
<meta
  name="Keywords"
  content="musica, música, musica independiente, música independiente, independiente, revista, critica, discos, entrevistas, conciertos, conciertos barcelona, fib, summercase, ola, daydream, primavera sound, primavera club, primavera"
/>
